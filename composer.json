{
    "name": "codenzia/laravel-superadmin",
    "description": "Protected super admin account for Laravel. Zero-config authorization via Gate::before, defense-in-depth Eloquent observer, optional Filament v4 plugin, vendor-only CLI commands with friction controls. Designed for vendor-deployed applications where customer admins must not accidentally delete the vendor's support account.",
    "keywords": [
        "codenzia",
        "laravel",
        "filament",
        "superadmin",
        "auth",
        "security",
        "break-glass",
        "recovery"
    ],
    "homepage": "https://github.com/codenzia/laravel-superadmin",
    "license": "MIT",
    "authors": [
        {
            "name": "Codenzia",
            "email": "dev@codenzia.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/notifications": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "filament/filament": "^4.0 || ^5.0",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "spatie/laravel-permission": "^6.16 || ^7.0 || ^8.0"
    },
    "suggest": {
        "filament/filament": "Required for the optional Filament v4 or v5 panel integration (hides destructive actions on the protected account)",
        "spatie/laravel-permission": "Required if you want the package to auto-assign a 'super_admin' role on install/restore"
    },
    "autoload": {
        "psr-4": {
            "Codenzia\\SuperAdmin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codenzia\\SuperAdmin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.5.x-dev"
        },
        "laravel": {
            "providers": [
                "Codenzia\\SuperAdmin\\SuperAdminServiceProvider"
            ],
            "aliases": {
                "SuperAdmin": "Codenzia\\SuperAdmin\\Facades\\SuperAdmin"
            }
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint --format agent"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
